      "item": [
        {
          "name": "List Blogs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_urls}}/blog/blogs/",
              "host": [
                "{{base_urls}}"
              ],
              "path": [
                "blog",
                "blogs",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.results && jsonData.results.length > 0) {",
                  "    pm.environment.set(\"blog_slug\", jsonData.results[0].slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
