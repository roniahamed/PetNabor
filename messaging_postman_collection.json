								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/messaging/threads/{{thread_id}}/messages/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"messaging",
								"threads",
								"{{thread_id}}",
								"messages",
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Send Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"message_type\": \"TEXT\",\n    \"text_content\": \"Hello world!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/messaging/threads/{{thread_id}}/messages/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"messaging",
								"threads",
								"{{thread_id}}",
								"messages",
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Send Reply",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"message_type\": \"TEXT\",\n    \"text_content\": \"Replying to your message\",\n    \"reply_to_id\": \"{{message_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/messaging/threads/{{thread_id}}/messages/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"messaging",
								"threads",
								"{{thread_id}}",
								"messages",
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete Message (Everyone)",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/messaging/threads/{{thread_id}}/messages/{{message_id}}/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"messaging",
								"threads",
								"{{thread_id}}",
								"messages",
								"{{message_id}}",
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Bulk Delete Messages",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"message_ids\": [\n        \"{{message_id_1}}\",\n        \"{{message_id_2}}\"\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/messaging/threads/{{thread_id}}/messages/bulk-delete/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"messaging",
								"threads",
								"{{thread_id}}",
								"messages",
								"bulk-delete",
								""
							]
						}
					},
					"response": []
				}
			]
		}
	],
