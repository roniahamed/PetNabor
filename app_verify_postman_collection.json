{
	"info": {
		"_postman_id": "c1f72b22-8951-4e08-bbbd-21db3a4ab1ba",
		"name": "App Verification (RevenueCat & Persona)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get Config",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{BASE_URL}}/verification/config/",
					"host": [
						"{{BASE_URL}}"
					],
					"path": [
						"verification",
						"config",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "Get User Verification Status",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{ACCESS_TOKEN}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{BASE_URL}}/verification/status/",
					"host": [
						"{{BASE_URL}}"
					],
					"path": [
						"verification",
						"status",
						""
					]
				}
			},
			"response": []
		},
        {
			"name": "Persona Session Initialization (Secure)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{ACCESS_TOKEN}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{BASE_URL}}/verification/persona-init/",
					"host": [
						"{{BASE_URL}}"
					],
					"path": [
						"verification",
						"persona-init",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "RevenueCat Webhook Simulation",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{REVENUECAT_WEBHOOK_SECRET}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"event\": {\n        \"event_timestamp_ms\": 1672531200000,\n        \"product_id\": \"app_verified_badge\",\n        \"period_type\": \"NORMAL\",\n        \"purchased_at_ms\": 1672531200000,\n        \"environment\": \"SANDBOX\",\n        \"entitlement_ids\": [\n            \"verified_persona\"\n        ],\n        \"presented_offering_id\": \"default_offering\",\n        \"transaction_id\": \"123456789\",\n        \"original_transaction_id\": \"123456789\",\n        \"is_family_share\": false,\n        \"country_code\": \"US\",\n        \"app_user_id\": \"<INSERT_USER_UUID_HERE>\",\n        \"type\": \"NON_RENEWING_PURCHASE\"\n    }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{BASE_URL}}/verification/webhook/",
					"host": [
						"{{BASE_URL}}"
					],
					"path": [
						"verification",
						"webhook",
						""
					]
				}
			},
			"response": []
		},
        {
			"name": "Persona Webhook Simulation",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-Persona-Signature",
						"value": "t=123456789,v1=",
						"type": "string",
                        "description": "Leave v1 blank locally to bypass, or ensure PERSONA_WEBHOOK_SECRET is empty locally"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"data\": {\n    \"attributes\": {\n      \"name\": \"inquiry.completed\",\n      \"payload\": {\n        \"data\": {\n          \"id\": \"inq_123456\",\n          \"type\": \"inquiry\",\n          \"attributes\": {\n            \"status\": \"completed\",\n            \"reference_id\": \"<INSERT_USER_UUID_HERE>\"\n          }\n        }\n      }\n    }\n  }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{BASE_URL}}/verification/persona-webhook/",
					"host": [
						"{{BASE_URL}}"
					],
					"path": [
						"verification",
						"persona-webhook",
						""
					]
				}
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:8001/api",
			"type": "string"
		},
		{
			"key": "ACCESS_TOKEN",
			"value": "your_jwt_here",
			"type": "string"
		},
		{
			"key": "REVENUECAT_WEBHOOK_SECRET",
			"value": "super_secret_webhook_token",
			"type": "string"
		}
	]
}
