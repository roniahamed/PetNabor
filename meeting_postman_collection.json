							"raw": "{{base_urls}}/meetings/requests/{{meeting_id}}/complete/",
							"host": [
								"{{base_urls}}"
							],
							"path": [
								"meetings",
								"requests",
								"{{meeting_id}}",
								"complete",
								""
							]
						}
					},
					"response": []
				},
				{
