{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PetNaborS3ReadWrite",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetBucketLocation",
                "s3:GetObjectAcl",
                "s3:PutObjectAcl"
            ],
            "Resource": [
                "arn:aws:s3:::petnabor-media",
                "arn:aws:s3:::petnabor-media/*"
            ]
        }
    ]
}
