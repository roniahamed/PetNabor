{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PetNaborRDSConnect",
            "Effect": "Allow",
            "Action": [
                "rds-db:connect"
            ],
            "Resource": [
                "arn:aws:rds-db:us-east-1:836567207606:dbuser:*/petnabor_user"
            ]
        },
        {
            "Sid": "PetNaborRDSDescribe",
            "Effect": "Allow",
            "Action": [
                "rds:DescribeDBInstances",
                "rds:DescribeDBClusters"
            ],
            "Resource": "*"
        }
    ]
}
