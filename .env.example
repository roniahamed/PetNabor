DEBUG=True
SECRET_KEY=your-super-secret-key-change-it-later
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,giving-sacred-minnow.ngrok-free.app
CSRF_TRUSTED_ORIGINS=https://giving-sacred-minnow.ngrok-free.app

POSTGRES_DB=petnabor_db
POSTGRES_USER=petnabor_user
POSTGRES_PASSWORD=petnabor_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Twilio (Phone OTP)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# OTP Configuration
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ─── Sentry Configuration (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
