DEBUG=True
SECRET_KEY=your-super-secret-key-change-it-later
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,giving-sacred-minnow.ngrok-free.app
CSRF_TRUSTED_ORIGINS=https://giving-sacred-minnow.ngrok-free.app

# ─── Local Database (Docker — for development)
POSTGRES_DB=petnabor_db
POSTGRES_USER=petnabor_user
POSTGRES_PASSWORD=petnabor_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── AWS RDS (Production PostgreSQL + PostGIS)
# Setup guide: docs/aws/04_rds_setup.md
USE_RDS=False                        # True in production, False for local dev
RDS_HOST=petnabor-db.xxxx.us-east-1.rds.amazonaws.com
RDS_DB=petnabor_db
RDS_USER=petnabor_user
RDS_PASSWORD=your-strong-rds-password
RDS_PORT=5432
POSTGRES_SSLMODE=require             # 'require' for RDS, 'prefer' for local

# Twilio (Phone OTP)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── AWS Credentials (SES, S3, CloudFront, RDS)
# IAM User: petnabor-ses-user (docs/aws/01_ses_setup.md)
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key
AWS_SESSION_TOKEN=your-session-token-if-using-sso   # SSO হলে লাগবে, permanent key হলে খালি রাখুন
AWS_DEFAULT_REGION=us-east-1

# ─── AWS SES (Email backend)
# Setup guide: docs/aws/01_ses_setup.md
AWS_SES_REGION_NAME=us-east-1
DEFAULT_FROM_EMAIL=noreply@petnabor.com

# ─── AWS S3 (Media + Static Storage)
# Setup guide: docs/aws/02_s3_setup.md
USE_S3=False                              # True in production, False for local dev
AWS_STORAGE_BUCKET_NAME=petnabor-media
AWS_S3_REGION_NAME=us-east-1
AWS_CLOUDFRONT_DOMAIN=                    # Feature 3-এ পূরণ করবেন (e.g. cdn.petnabor.com)

# OTP Configuration
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EXPIRY_HOURS=24
